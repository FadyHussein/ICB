# Server Configuration
PORT=5000
NODE_ENV=development

# Excel File Configuration
# Development: Uses relative path to local data directory
# Production (Render): Uses /var/data (Render's persistent disk)
EXCEL_FILE_PATH=../data/master-data.xlsx
BACKUP_DIR=../data/backups

# Backup Settings
BACKUP_RETENTION_DAYS=30
MAX_BACKUPS=50

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ATTENDANCE_MAX=30
RATE_LIMIT_BULK_MAX=10

# CORS Settings
# Development: http://localhost:5173 (Vite dev server)
# Production: https://icbsundayschool.onrender.com (or your Render domain)
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info
LOG_FILE=../logs/server.log
